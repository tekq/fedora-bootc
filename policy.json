{
    "default": [
        {
            "type": "reject"
        }
    ],
    "transports": {
        "docker": {
            "quay.io/asmx2/fedora-bootc": [
                {
                    "type": "sigstoreSigned",
                    "keyPath": "/etc/pki/containers/asmx2-bootc.pub",
                    "signedIdentity": {
                        "type": "matchRepository"
                    }
                }
            ],
            "registry.fedoraproject.org": [
                  { "type": "insecureAcceptAnything" }
            ],
            "docker.io": [
                { "type": "insecureAcceptAnything" }
            ],
            "quay.io": [
                { "type": "insecureAcceptAnything" }
            ],
            "ghcr.io": [
                { "type": "insecureAcceptAnything" }
            ]
        }
    }
}